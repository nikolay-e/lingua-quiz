{
  "name": "@lingua-quiz/frontend",
  "version": "1.0.6",
  "description": "Frontend application for Lingua Quiz",
  "keywords": [
    "react",
    "frontend",
    "language-learning",
    "quiz"
  ],
  "type": "module",
  "scripts": {
    "audit:all": "npm run lint:css && npm run typecheck && echo 'All audits passed!'",
    "build": "npm run build --workspace=@lingua-quiz/core && tsc -b && vite build",
    "build-storybook": "storybook build",
    "dev": "npm run build --workspace=@lingua-quiz/core && vite",
    "format": "prettier --write .",
    "lighthouse": "lhci autorun --config=lighthouserc.json",
    "lighthouse:ci": "npm run build && npm run preview & sleep 3 && npm run lighthouse",
    "lint": "prettier --check . && eslint .",
    "lint:css": "stylelint 'src/**/*.css'",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lingua-quiz/core": "file:../core",
    "@lingua-quiz/domain": "file:../domain",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.90.16",
    "class-variance-authority": "^0.7.1",
    "i18next": "^25.8.0",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.562.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^16.5.3",
    "react-router-dom": "^7.6.1",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@chromatic-com/storybook": "^5.0.0",
    "@lhci/cli": "^0.15.1",
    "@storybook/addon-a11y": "^10.2.0",
    "@storybook/addon-docs": "^10.2.0",
    "@storybook/addon-onboarding": "^10.2.0",
    "@storybook/addon-vitest": "^10.2.0",
    "@storybook/react-vite": "^10.2.0",
    "@stylelint/postcss-css-in-js": "^0.38.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/browser-playwright": "^4.0.17",
    "@vitest/coverage-v8": "^4.0.18",
    "clsx": "^2.1.1",
    "eslint-plugin-storybook": "^10.2.0",
    "lighthouse": "^13.0.1",
    "playwright": "^1.57.0",
    "postcss-html": "^1.8.1",
    "storybook": "^10.1.11",
    "stylelint": "^17.0.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "tailwind-merge": "^3.4.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.0.1",
    "vitest": "^4.0.17"
  }
}
