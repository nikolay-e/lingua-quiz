{
  "name": "@lingua-quiz/frontend",
  "version": "1.0.6",
  "description": "Frontend application for Lingua Quiz",
  "keywords": [
    "react",
    "frontend",
    "language-learning",
    "quiz"
  ],
  "type": "module",
  "scripts": {
    "build": "npm run build --workspace=@lingua-quiz/core && tsc -b && vite build",
    "dev": "npm run build --workspace=@lingua-quiz/core && vite",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lingua-quiz/core": "file:../core",
    "@lingua-quiz/domain": "file:../domain",
    "@tanstack/react-query": "^5.90.16",
    "i18next": "^24.2.3",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.562.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^15.5.2",
    "react-router-dom": "^7.6.1",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.4.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.0.1"
  }
}
