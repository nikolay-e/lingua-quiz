{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "workspaces": {
    ".": {
      "entry": [],
      "project": []
    },
    "apps/frontend": {
      "entry": ["src/main.tsx", "vite.config.ts", ".storybook/main.ts", ".storybook/preview.ts"],
      "project": ["src/**/*.{ts,tsx}", "src/**/*.stories.tsx"],
      "paths": {
        "@/*": ["./src/*"],
        "@app/*": ["./src/app/*"],
        "@pages": ["./src/pages"],
        "@pages/*": ["./src/pages/*"],
        "@features/*": ["./src/features/*"],
        "@shared/*": ["./src/shared/*"],
        "@api": ["./src/api"],
        "@api/*": ["./src/api/*"]
      }
    },
    "packages/core": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/domain": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/api-client": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    }
  },
  "ignore": ["**/generated/**", "**/node_modules/**"],
  "ignoreDependencies": [
    "sort-package-json",
    "@axe-core/playwright",
    "lighthouse",
    "postcss-html",
    "stylelint-config-html",
    "@stylelint/postcss-css-in-js",
    "@vitest/coverage-v8",
    "eslint-plugin-storybook",
    "playwright",
    "openapi-typescript-codegen"
  ],
  "ignoreBinaries": ["check_image", "sleep"],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "exports": "off"
  }
}
